generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Administradores e gestores da plataforma
model User {
  id        String     @id
  name      String
  email     String     @unique
  password  String
  role      Role       @default(MANAGER)
  status    UserStatus @default(PENDING)
  avatar    String?
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email])
  @@index([status])
  @@map("users")
}

/// Alunos inscritos na plataforma
model Student {
  id          String        @id
  name        String
  email       String        @unique
  phone       String?
  avatar      String?
  status      StudentStatus @default(PENDING)
  joinDate    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  password    String
  enrollments Enrollment[]
  payments    Payment[]

  @@index([email])
  @@index([status])
  @@map("students")
}

/// Formadores/instrutores dos cursos
model Instructor {
  id                String             @id
  name              String
  photo             String?
  specialization    String
  yearsExperience   Int                @default(0)
  bio               String
  education         String
  phone             String?
  professionalEmail String?
  status            InstructorStatus   @default(ACTIVO)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  courses           CourseInstructor[]

  @@index([status])
  @@map("instructors")
}

/// Categorias de cursos
model Category {
  id          String   @id
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]

  @@map("categories")
}

/// Cursos disponíveis na plataforma
model Course {
  id              String             @id
  title           String
  description     String
  thumbnail       String?
  categoryId      String
  category        Category           @relation(fields: [categoryId], references: [id])
  level           CourseLevel        @default(INICIANTE)
  type            CourseType         @default(ONLINE)
  status          CourseStatus       @default(RASCUNHO)
  objectives      String[]
  targetAudience  String[]
  requirements    String[]
  rating          Float              @default(0)
  reviewCount     Int                @default(0)
  studentsCount   Int                @default(0)
  duration        String?
  locationDefault String?
  price           Float
  discountPrice   Float?
  longDescription String?
  objective       String?
  skills          String[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  classes         CourseClass[]
  instructors     CourseInstructor[]
  enrollments     Enrollment[]
  modules         Module[]
  payments        Payment[]

  @@index([status])
  @@index([categoryId])
  @@index([type])
  @@index([status, categoryId])
  @@map("courses")
}

/// Tabela de junção N:N entre Cursos e Instrutores
model CourseInstructor {
  courseId     String
  instructorId String
  assignedAt   DateTime   @default(now())
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@id([courseId, instructorId])
  @@index([instructorId])
  @@map("course_instructors")
}

/// Módulos de um curso (capítulos/secções)
model Module {
  id        String       @id
  courseId  String
  title     String
  order     Int
  status    ModuleStatus @default(DRAFT)
  duration  String?
  topics    String[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  lessons   Lesson[]
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, order])
  @@map("modules")
}

/// Aulas dentro de um módulo
model Lesson {
  id        String      @id
  moduleId  String
  title     String
  type      LessonType? @default(VIDEO)
  content   String?
  duration  String?
  order     Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  module    Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, order])
  @@map("lessons")
}

/// Turmas de um curso (para modalidades PRESENCIAL/HIBRIDO)
model CourseClass {
  id            String            @id
  courseId      String
  name          String
  startDate     DateTime?
  endDate       DateTime?
  schedule      String
  location      String
  vacancies     Int
  enrolledCount Int               @default(0)
  status        CourseClassStatus @default(ABERTA)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  course        Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([status])
  @@index([startDate])
  @@map("course_classes")
}

/// Inscrições de alunos em cursos
model Enrollment {
  id        String           @id
  studentId String
  courseId  String
  progress  Int              @default(0)
  status    EnrollmentStatus @default(PENDING)
  contact   String?
  date      DateTime         @default(now())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
  @@index([courseId, status])
  @@map("enrollments")
}

/// Pagamentos de alunos para inscrição em cursos
model Payment {
  id              String        @id
  studentId       String
  courseId        String
  studentName     String
  courseName      String
  amount          Float
  paymentProof    String
  status          PaymentStatus @default(PENDING)
  rejectionReason String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  course          Course        @relation(fields: [courseId], references: [id])
  student         Student       @relation(fields: [studentId], references: [id])

  @@index([status])
  @@index([studentId])
  @@index([courseId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("payments")
}

/// Refresh tokens persistidos para revogação segura (admin + student portals)
model RefreshToken {
  id        String   @id
  token     String   @unique
  portal    String
  entityId  String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([entityId, portal])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

enum Role {
  ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  PENDING
  DROPPED
}

enum InstructorStatus {
  ACTIVO
  INACTIVO
}

enum CourseType {
  ONLINE
  PRESENCIAL
  HIBRIDO
}

enum CourseStatus {
  RASCUNHO
  PUBLICADO
  ENCERRADO
}

enum CourseLevel {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

enum ModuleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXTO
  QUIZ
  LIVE
}

enum CourseClassStatus {
  ABERTA
  LOTADA
  FINALIZADA
}

enum EnrollmentStatus {
  ACTIVE
  PENDING
  COMPLETED
  DROPPED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}
